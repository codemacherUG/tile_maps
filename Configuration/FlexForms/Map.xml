<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <TCEforms>
          <sheetTitle>Map Settings</sheetTitle>
        </TCEforms>
        <type>array</type>
        <el>
          <settings.tileendpoint>
            <TCEforms>
              <label>LLL:EXT:tile_maps/Resources/Private/Language/locallang_be.xlf:content_element.map.settings.endpoint</label>
              <config>
                <type>select</type>
                <renderType>selectSingle</renderType>
                <foreign_table>pages</foreign_table>
                <minitems>1</minitems>
                <foreign_table_where>AND doktype = 601</foreign_table_where>
            </config>
            </TCEforms>
          </settings.tileendpoint>
          <settings.bbox>
            <label>
                LLL:EXT:tile_proxy/Resources/Private/Language/locallang.xlf:tx_tileproxy_flexform.settings.bbox</label>
            <config>
                <type>user</type>
                <renderType>boundingboxmap</renderType>
                <eval>trim,required</eval>
                <default>11.86,51.41,12.07,51.55</default>
                <parameters>
                    <decimalPlaces>8</decimalPlaces>
                </parameters>
            </config>
        </settings.bbox>          
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>